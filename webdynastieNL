<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WebDynastieNL</title>
<style>
    /* ===== BASIS STIJL ===== */
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background-color: #000;
        color: #fff;
        line-height: 1.6;
    }
    a { text-decoration: none; color: inherit; }
    h1, h2, h3 { color: #FFD700; } /* Goud */
    .container { width: 90%; max-width: 1200px; margin: auto; padding: 50px 0; }

    /* ===== NAVBAR ===== */
    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 50px;
        background-color: rgba(0,0,0,0.9);
        position: sticky;
        top: 0;
        z-index: 1000;
    }
    nav a { margin: 0 15px; font-weight: bold; transition: 0.3s; }
    nav a:hover { color: #FFD700; }

    /* ===== BUTTONS ===== */
    .btn {
        background: #FFD700;
        color: #000;
        padding: 12px 30px;
        border: none;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }
    .btn:hover {
        background: #fff;
        color: #000;
        transform: scale(1.05);
    }

    /* ===== SECTIES ===== */
    section { padding: 80px 0; }
    .highlight { color: #FFD700; font-weight: bold; }

    /* ===== DYNAMISCHE TEKST ===== */
    #dynamic-text { font-size: 2rem; text-align: center; margin-top: 20px; }

    /* ===== PORTFOLIO ===== */
    .portfolio-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px; }
    .portfolio-item {
        background: #111;
        padding: 20px;
        cursor: pointer;
        transition: transform 0.3s, box-shadow 0.3s;
    }
    .portfolio-item:hover {
        transform: translateY(-10px);
        box-shadow: 0 0 20px #FFD700;
    }

    /* ===== MODAL ===== */
    .modal {
        display: none;
        position: fixed;
        z-index: 2000;
        left: 0; top: 0;
        width: 100%; height: 100%;
        background: rgba(0,0,0,0.9);
        justify-content: center;
        align-items: center;
    }
    .modal-content {
        background: #111;
        padding: 30px;
        border: 2px solid #FFD700;
        max-width: 600px;
        width: 90%;
        text-align: center;
        position: relative;
    }
    .close-modal {
        position: absolute;
        top: 15px;
        right: 20px;
        cursor: pointer;
        font-size: 1.5rem;
        color: #FFD700;
    }

    /* ===== CONTACT ===== */
    form {
        display: flex;
        flex-direction: column;
        gap: 15px;
        max-width: 500px;
        margin: auto;
    }
    input, textarea {
        padding: 12px;
        border: none;
        border-radius: 5px;
    }

    /* ===== LIVE CHAT BUTTON ===== */
    #chat-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: #FFD700;
        color: #000;
        padding: 15px 20px;
        border-radius: 50px;
        cursor: pointer;
        font-weight: bold;
        box-shadow: 0 0 15px #FFD700;
        z-index: 1500;
        transition: transform 0.3s;
    }
    #chat-btn:hover { transform: scale(1.1); }

    #chat-box {
        display: none;
        position: fixed;
        bottom: 90px;
        right: 30px;
        width: 300px;
        max-height: 400px;
        background: #111;
        color: #fff;
        border: 2px solid #FFD700;
        border-radius: 10px;
        padding: 20px;
        overflow-y: auto;
        z-index: 1500;
    }
</style>
</head>
<body>

<!-- NAVBAR -->
<nav>
    <div class="logo"><h2>WebDynastieNL</h2></div>
    <div>
        <a href="#home">Home</a>
        <a href="#over">Over ons</a>
        <a href="#diensten">Diensten</a>
        <a href="#portfolio">Portfolio</a>
        <a href="#klanten">Klanten</a>
        <a href="#contact">Contact</a>
    </div>
</nav>

<!-- HOME -->
<section id="home" class="container">
    <h1>Welkom bij <span class="highlight">WebDynastieNL</span></h1>
    <p id="dynamic-text"></p>
    <button class="btn">Neem contact op</button>
</section>

<!-- OVER ONS -->
<section id="over" class="container">
    <h2>Over ons</h2>
    <p>Wij zijn <span class="highlight">WebDynastieNL</span>, gespecialiseerd in high-end, maatwerk websites. Wij combineren <span class="highlight">luxe uitstraling</span> met strategisch design voor klanten die serieus online willen groeien.</p>
</section>

<!-- DIENSTEN -->
<section id="diensten" class="container">
    <h2>Diensten</h2>
    <ul>
        <li>High-end maatwerk websites</li>
        <li>Branding & luxe webdesign</li>
        <li>Webapplicaties & strategie</li>
        <li>SEO & marketing optimalisatie</li>
        <li>Onderhoud & support</li>
    </ul>
</section>

<!-- PORTFOLIO -->
<section id="portfolio" class="container">
    <h2>Portfolio</h2>
    <div class="portfolio-grid">
        <div class="portfolio-item" data-title="Project 1" data-desc="High-end website voor luxe merk">Project 1</div>
        <div class="portfolio-item" data-title="Project 2" data-desc="Custom webshop met exclusief design">Project 2</div>
        <div class="portfolio-item" data-title="Project 3" data-desc="Strategische webapplicatie voor corporate">Project 3</div>
    </div>
</section>

<!-- MODAL -->
<div class="modal" id="modal">
    <div class="modal-content">
        <span class="close-modal">&times;</span>
        <h3 id="modal-title"></h3>
        <p id="modal-desc"></p>
    </div>
</div>

<!-- KLANTEN / TESTIMONIALS -->
<section id="klanten" class="container">
    <h2>Klanten & Testimonials</h2>
    <p>"WebDynastieNL heeft onze online aanwezigheid volledig getransformeerd. Luxe, strategisch en modern!" – Klant A</p>
    <p>"Een top partner voor high-end projecten en exclusieve branding." – Klant B</p>
</section>

<!-- CONTACT -->
<section id="contact" class="container">
    <h2>Contact</h2>
    <form id="contact-form">
        <input type="text" placeholder="Naam" required>
        <input type="email" placeholder="Email" required>
        <textarea placeholder="Bericht" rows="5" required></textarea>
        <button type="submit" class="btn">Verstuur</button>
    </form>
</section>

<!-- LIVE CHAT -->
<div id="chat-btn">Chat</div>
<div id="chat-box">
    <p>Hallo! Hoe kunnen we je helpen?</p>
    <input type="text" placeholder="Typ hier..." id="chat-input">
</div>

<script>
/* ===== DYNAMISCHE TEKST ===== */
const dynamicTexts = [
    "Wij bouwen high-end maatwerk websites.",
    "Strategisch design voor exclusieve klanten.",
    "Uw online luxe-imperium begint hier.",
    "Modern, opvallend en professioneel."
];
let index = 0;
const dynamicEl = document.getElementById('dynamic-text');
setInterval(() => {
    dynamicEl.textContent = dynamicTexts[index];
    index = (index + 1) % dynamicTexts.length;
}, 3000);

/* ===== MODAL PORTFOLIO ===== */
const portfolioItems = document.querySelectorAll('.portfolio-item');
const modal = document.getElementById('modal');
const modalTitle = document.getElementById('modal-title');
const modalDesc = document.getElementById('modal-desc');
const closeModal = document.querySelector('.close-modal');

portfolioItems.forEach(item => {
    item.addEventListener('click', () => {
        modal.style.display = 'flex';
        modalTitle.textContent = item.dataset.title;
        modalDesc.textContent = item.dataset.desc;
    });
});
closeModal.addEventListener('click', () => { modal.style.display = 'none'; });
window.addEventListener('click', e => { if(e.target === modal) modal.style.display = 'none'; });

/* ===== CONTACT FORM ===== */
const form = document.getElementById('contact-form');
form.addEventListener('submit', e => {
    e.preventDefault();
    alert("Bedankt! We nemen zo snel mogelijk contact op.");
    form.reset();
});

/* ===== LIVE CHAT ===== */
const chatBtn = document.getElementById('chat-btn');
const chatBox = document.getElementById('chat-box');
const chatInput = document.getElementById('chat-input');

chatBtn.addEventListener('click', () => {
    chatBox.style.display = chatBox.style.display === 'block' ? 'none' : 'block';
});

chatInput.addEventListener('keypress', e => {
    if(e.key === 'Enter' && chatInput.value.trim() !== "") {
        const msg = document.createElement('p');
        msg.textContent = "Je: " + chatInput.value;
        chatBox.appendChild(msg);
        chatInput.value = "";
        chatBox.scrollTop = chatBox.scrollHeight;
    }
});
</script>
</body>
</html>
